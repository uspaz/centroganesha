---
const navLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "¿Qué es Reiki?", href: "#reiki" },
  { label: "Origen", href: "#origen" },
  { label: "Beneficios", href: "#beneficios" },
  { label: "Sobre mí", href: "#sobre-mi" },
  { label: "Servicios", href: "#servicios" },
  { label: "Contacto", href: "#contacto" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-ganesha-primary-dark/90 backdrop-blur-sm"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="#inicio"
        class="font-heading text-xl text-ganesha-cream tracking-wider italic"
      >
        Centro Ganesha
      </a>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[11px] text-ganesha-cream/80 hover:text-ganesha-accent uppercase tracking-[0.15em] transition-colors duration-300"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="lg:hidden text-ganesha-cream p-2"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            id="icon-open"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
          <path
            id="icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <ul class="flex flex-col gap-3">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="mobile-link block text-sm text-ganesha-cream/80 hover:text-ganesha-accent uppercase tracking-widest transition-colors duration-300 py-2"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Cerrar menú al hacer clic en un enlace
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
