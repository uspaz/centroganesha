---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ganesha-primary-dark text-ganesha-cream/70 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <a
          href="#inicio"
          class="font-heading text-2xl text-ganesha-cream tracking-wider"
        >
          Centro Ganesha
        </a>
        <p class="mt-3 text-sm leading-relaxed max-w-xs">
          Sanación del cuerpo, la mente y el espíritu. Un espacio de paz y
          armonización energética.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-heading text-lg text-ganesha-cream mb-4">Navegación</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="#reiki"
              class="text-sm hover:text-ganesha-accent transition-colors duration-300"
              >Reiki</a>
          </li>
          <li>
            <a
              href="#beneficios"
              class="text-sm hover:text-ganesha-accent transition-colors duration-300"
              >Beneficios</a>
          </li>
          <li>
            <a
              href="#servicios"
              class="text-sm hover:text-ganesha-accent transition-colors duration-300"
              >Servicios</a>
          </li>
          <li>
            <a
              href="#contacto"
              class="text-sm hover:text-ganesha-accent transition-colors duration-300"
              >Contacto</a>
          </li>
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h4 class="font-heading text-lg text-ganesha-cream mb-4">Contacto</h4>
        <ul class="space-y-2 text-sm">
          <li>✉ fabianasazales@centroganesha.com</li>
          <li>📍 Salto, Uruguay</li>
        </ul>
      </div>
    </div>

    <!-- Divider & copyright -->
    <div class="border-t border-ganesha-cream/10 pt-8 text-center">
      <p class="text-xs text-ganesha-cream/50">
        © {currentYear} Centro Ganesha. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
