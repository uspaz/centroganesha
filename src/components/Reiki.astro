---
import { Image } from "astro:assets";
import meditacionImg from "../assets/meditacion.webp";
---

<section
  id="reiki"
  class="min-h-screen bg-ganesha-cream flex items-center overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 w-full py-16 lg:py-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left: Texto -->
      <div class="order-2 lg:order-1">
        <h2
          class="font-heading text-[clamp(2.2rem,5vw,3.8rem)] leading-[1.1] text-ganesha-text mb-10 font-normal scroll-hidden"
          data-scroll="fade-in-left"
        >
          <em class="text-ganesha-primary italic">Reiki</em> significa Energía Vital
          Universal
        </h2>

        <!-- Cita con borde izquierdo -->
        <blockquote
          class="border-l-2 border-ganesha-accent pl-6 max-w-[420px] scroll-hidden"
          data-scroll="fade-in-left"
          style="animation-delay: 0.25s"
        >
          <p class="text-[0.95rem] leading-7 text-ganesha-text-light italic">
            "El Reiki cura enfermedades y te libera de la depresión, la
            debilidad, el miedo, la indecisión, el nerviosismo, la decepción y
            otros problemas derivados de los malos hábitos."
          </p>
        </blockquote>
      </div>

      <!-- Right: Imagen con fondo decorativo -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div
          class="relative w-[clamp(260px,70vw,380px)] lg:w-[clamp(280px,55vw,460px)] aspect-[3/4] mx-auto lg:mx-0 scroll-hidden"
          data-scroll="scale-in"
        >
          <!-- Fondo verde decorativo -->
          <div
            class="absolute -top-5 -right-5 lg:-top-7 lg:-right-7 w-full h-[80%] bg-ganesha-primary rounded-md"
          >
          </div>

          <!-- Borde dorado decorativo -->
          <div
            class="absolute -bottom-4 -left-4 lg:-bottom-6 lg:-left-6 w-full h-full border-2 border-ganesha-accent rounded-md"
          >
          </div>

          <!-- Imagen principal -->
          <Image
            src={meditacionImg}
            alt="Mujer meditando en posición de loto"
            class="relative z-10 w-full h-full object-cover rounded-md shadow-[0_10px_40px_rgba(0,0,0,0.12)]"
            widths={[480, 1920]}
            sizes="(max-width: 640px) 480, (max-width: 1024px) 70vw, 1920px"
            format="webp"
            quality={85}
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
